{
  "name": "the-deleometer",
  "version": "1.0.2-beta.33",
  "description": "A plugin for deep self-discovery journaling using AI. Use analysis history, and export options. Requires an OpenAI API key.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "emotional-analysis",
    "journaling",
    "ai"
  ],
  "author": "Michelle G Dyason",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichelleGDyason/The_Obsidian_Deleometer_v2.git"
  },
  "bugs": {
    "url": "https://github.com/MichelleGDyason/The_Obsidian_Deleometer_v2/issues"
  },
  "homepage": "https://github.com/MichelleGDyason/The_Obsidian_Deleometer_v2#readme",
  "funding": [
    "https://buymeacoffee.com/theobsidiandeleometer",
    "https://github.com/sponsors/MichelleGDyason"
  ],
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^16.11.6",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.4.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^4.9.5",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "openai": "^4.20.0"
  }
}
